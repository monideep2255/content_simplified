# Copy this file to .env and fill in real values. Never commit .env.

# Postgres connection string (Neon serverless Postgres).
# Required. The server throws on startup if this is missing.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# DeepSeek API key. Required. This is the app's AI provider for all
# simplification and follow-up requests.
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Port the server binds to. The host injects this in production.
# Defaults to 5000 locally if unset.
PORT=5000
